[Unit]
Description=Bitcoin Cash Node Daemon (Chipnet)
After=network.target

[Service]
Type=simple
User={{ bchn_user }}
Group={{ bchn_user }}
ExecStart=/usr/local/bin/bitcoind -conf={{ bchn_chipnet_config_file }} -datadir={{ bchn_chipnet_data_dir }}
ExecStop=/usr/local/bin/bitcoin-cli -conf={{ bchn_chipnet_config_file }} -datadir={{ bchn_chipnet_data_dir }} stop
Restart=on-failure
RestartSec=10
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
